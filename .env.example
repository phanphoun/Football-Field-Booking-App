# Football Field Booking App - Environment Configuration
# Copy this file to .env and fill in the appropriate values for your environment

# =========== Server Configuration ===========
NODE_ENV=production
PORT=5000

# =========== JWT & Security ===========
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-required-for-production
JWT_EXPIRATION=7d

# =========== Database Configuration ===========
DB_HOST=localhost
DB_PORT=3306
DB_NAME=football_booking_db
DB_USER=root
DB_PASSWORD=your_database_password_here
DB_DIALECT=mysql

# For AWS RDS MySQL
# DB_HOST=your-rds-endpoint.region.rds.amazonaws.com
# DB_PORT=3306
# DB_SSL=true
# DB_SSL_MODE=REQUIRED

# =========== CORS & Frontend ===========
CORS_ORIGIN=https://app.example.com
FRONTEND_URL=https://app.example.com
REACT_APP_API_URL=https://api.example.com/api

# =========== File Upload Configuration ===========
# Local file upload paths
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/jpg,image/png,image/gif,image/webp
ALLOWED_FILE_EXTENSIONS=.jpg,.jpeg,.png,.gif,.webp

# For AWS S3 (optional - currently uses local storage)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_S3_BUCKET=your-bucket-name

# =========== Email Configuration ===========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@footballbooking.com

# =========== External APIs ===========
FOOTBALL_API_KEY=your_football_data_org_api_key
APP_TIMEZONE=Asia/Bangkok

# =========== Logging ===========
LOG_LEVEL=info

# =========== Optional: Admin User (for initial setup) ===========
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=secure_admin_password_change_this
