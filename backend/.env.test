NODE_ENV=development
PORT=5000
APP_TIMEZONE=Asia/Bangkok

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=football_booking_test
DB_USER=root
DB_PASSWORD=
DB_DIALECT=mysql
DB_SSL=false
DB_LOGGING=false
DB_SYNC_ALTER=false

# JWT
JWT_SECRET=test_jwt_secret_for_development_minimum_32_characters
JWT_EXPIRES_IN=7d

# Frontend
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Features
RATE_LIMITING=true
HTTP_LOGGING=false
LOG_LEVEL=dev
DB_LOGGING=false

# File uploads
MAX_FILE_SIZE=5242880
UPLOAD_DESTINATION=uploads/
