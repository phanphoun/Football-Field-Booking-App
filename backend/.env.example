# ========================================
# SERVER CONFIGURATION
# ========================================
NODE_ENV=development
PORT=5000
APP_NAME=Football Field Booking API
APP_VERSION=1.0.0

# ========================================
# DATABASE CONFIGURATION
# ========================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=football_booking
DB_DIALECT=mysql
DB_LOGGING=false

# Production: Use external database with SSL
# DB_SSL=true
# DB_POOL_MIN=5
# DB_POOL_MAX=20

# ========================================
# JWT CONFIGURATION (IMPORTANT: Change in production!)
# ========================================
# MINIMUM 32 characters, use cryptographically random string
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your_refresh_secret_minimum_32_characters_long
JWT_REFRESH_EXPIRES_IN=7d

# ========================================
# CORS CONFIGURATION
# ========================================
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# ========================================
# SECURITY CONFIGURATION
# ========================================
RATE_LIMIT_AUTH=5          # Max login attempts per 15 min (production)
RATE_LIMIT_API=100         # Max API requests per minute (production)
RATE_LIMIT_GLOBAL=1000     # Max global requests per minute (production)

# File upload settings
MAX_FILE_SIZE=5242880      # 5MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# ========================================
# EXTERNAL API KEYS
# ========================================
# Get from https://www.football-data.org/client/register
FOOTBALL_API_KEY=your_api_key_here

# ========================================
# TIMEZONE
# ========================================
APP_TIMEZONE=Asia/Bangkok

# ========================================
# LOGGING CONFIGURATION
# ========================================
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# ========================================
# MONITORING (Optional)
# ========================================
# SENTRY_DSN=https://your-sentry-dsn
# APM_ENABLED=false

# ========================================
# EMAIL CONFIGURATION (For future use)
# ========================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
