# Backend Configuration - DO NOT COMMIT YOUR .env FILE!
# Copy this file to .env and fill in your local values
# This template has safe defaults for development

# ============================================
# APPLICATION SETTINGS
# ============================================

# Node environment
NODE_ENV=development
PORT=5000
APP_TIMEZONE=Asia/Bangkok

# ============================================
# DATABASE
# ============================================

# MySQL Connection (local development)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=football_booking
DB_USER=root
DB_PASSWORD=

# Database options
DB_DIALECT=mysql
DB_SSL=false
DB_LOGGING=false
DB_SYNC_ALTER=false

# ============================================
# SECURITY - JWT
# ============================================

# JWT Secret (MUST be at least 32 characters!)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_minimum_32_characters_required_for_security

# JWT expiration
JWT_EXPIRES_IN=7d

# ============================================
# EXTERNAL APIs
# ============================================

# Football Data API (get from https://www.football-data.org/client/register)
FOOTBALL_API_KEY=your_football_api_key_here

# Google OAuth (get from https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ============================================
# FRONTEND
# ============================================

# Frontend URL for CORS
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ============================================
# FEATURES
# ============================================

# Enable/disable features
RATE_LIMITING=true
HTTP_LOGGING=true

# Logging configuration
LOG_LEVEL=dev
DB_LOGGING=false

# ============================================
# FILE UPLOADS
# ============================================

# Max file size in bytes (5MB default)
MAX_FILE_SIZE=5242880

# Upload destination
UPLOAD_DESTINATION=uploads/

# ============================================
# OPTIONAL - AWS
# ============================================

# AWS Region (if using AWS services)
AWS_REGION=us-east-1

# AWS S3 bucket for backups (if using S3)
AWS_S3_BUCKET=football-booking-uploads

# RDS SSL CA Certificate (if using RDS with SSL)
# DB_SSL_CA_CERT=-----BEGIN CERTIFICATE-----...-----END CERTIFICATE-----

# ============================================
# OPTIONAL - MONITORING
# ============================================

# Sentry error tracking (optional)
# SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# ============================================
# INSTRUCTIONS
# ============================================

# 1. Copy this to .env: cp .env.example .env
# 2. Fill in the required variables above
# 3. Run locally: npm run dev
# 4. For Docker: docker-compose up
#
# IMPORTANT:
# - Never commit .env to git (use .env.example instead)
# - Use strong JWT_SECRET (min 32 chars)
# - In production, use AWS Secrets Manager for credentials
